# Example Environment Configuration
# Copy this file to .env and fill in your values
# ⚠️ NEVER commit .env to version control!

# =================================
# 🤖 COPILOT API Configuration
# =================================
COPILOT_API_URL=http://localhost:4141/v1/chat/completions
COPILOT_API_MODEL=claude-sonnet-4-20250514

# =================================
# 📱 WhatsApp Authentication
# =================================
# Options: 'qr' or 'pairing'
WA_AUTH_METHOD=pairing
# Your WhatsApp phone number (with country code, no +)
WA_PHONE_NUMBER=628xxxxxxxxxx

# =================================
# 🏥 Health Check Server
# =================================
HEALTH_CHECK_PORT=8008
# ⚠️ IMPORTANT: In production, keep this as localhost
# Only change if behind authenticated reverse proxy
HEALTH_HOST=localhost

# =================================
# ☁️ Cloudflare DNS (Optional)
# =================================
# Leave empty if not using DNS automation
CF_ZONE_ID=your_zone_id
CF_ACCOUNT_ID=your_account_id
CF_GLOBAL_API_KEY=your_global_api_key
CF_GLOBAL_CA_KEY=your_global_ca_key
CF_DNS_API_TOKEN=your_dns_api_token
CF_TARGET_DOMAIN=your_target_domain

# =================================
# 📝 Logging
# =================================
# Options: 'error', 'warn', 'info', 'debug', 'trace'
LOG_LEVEL=info

# =================================
# 🗄️ Database
# =================================
# SQLite database path (relative to project root)
DB_PATH=data/chat_memory.db

# =================================
# ⏰ Session Configuration
# =================================
# Session expiry in hours (0 = never expire)
SESSION_EXPIRY_HOURS=24

# Bot persona name
BOT_NAME=Tama

# =================================
# 🐛 Bug Reporter
# =================================
# Owner's WhatsApp number for automatic bug reports (with country code, no +)
# When errors occur, the bot auto-reports to this number
BUG_REPORT_OWNER=6282210819939

# =================================
# 📊 Dashboard Admin Panel
# =================================
DASHBOARD_PORT=6680
DASHBOARD_SESSION_HOURS=24
# Default admin credentials (change after first login!)
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASS=admin123

# =================================
# 🎨 Image Generation (Optional)
# =================================
# OpenAI API key for DALL-E 3 image generation
# Leave empty to disable /imagine command
OPENAI_API_KEY=

# =================================
# 🎬 GIF Search (Optional)
# =================================
# At least one key needed for /gif command
TENOR_API_KEY=
GIPHY_API_KEY=

# =================================
# 🔍 V5: Live Verification (Optional)
# =================================
# Enable/disable automatic live verification of AI responses
# 'true' = enabled (default), 'false' = disabled
LIVE_VERIFY_ENABLED=true
# Timeout for verification searches (ms)
LIVE_VERIFY_TIMEOUT_MS=15000

# 📝 V5: Video Notes (Optional)
# =================================
# Enable/disable video notes extraction from YouTube
VIDEO_NOTES_ENABLED=true
# Max video duration for notes (seconds, default 1800 = 30min)
VIDEO_NOTES_MAX_DURATION=1800

# 🧠 V5: Smart Reasoning (Optional)
# =================================
# Enable/disable chain-of-thought reasoning
REASONING_ENABLED=true
# Timeout for reasoning API calls (ms, default 120000 = 2min)
REASONING_TIMEOUT_MS=120000

# 📚 V5: RAG Document Intelligence (Optional)
# =============================================
# Enable/disable RAG pipeline
RAG_ENABLED=true
# Chunk size for document splitting (chars, default 500)
RAG_CHUNK_SIZE=500
# Overlap between chunks (chars, default 100)
RAG_CHUNK_OVERLAP=100
# Number of top results to retrieve (default 5)
RAG_TOP_K=5
# Max context chars sent to AI (default 6000)
RAG_MAX_CONTEXT_CHARS=6000
# Minimum relevance score 0-1 (default 0.35)
RAG_MIN_RELEVANCE=0.35
# AI temperature for RAG answers (default 0.4)
RAG_TEMPERATURE=0.4
# Max document size for ingestion (bytes, default 500000 = 500KB)
RAG_MAX_INGEST_SIZE=500000
# Max vectors in store (default 10000)
VECTOR_STORE_MAX_SIZE=10000
# Similarity threshold for vector search (default 0.3)
VECTOR_SIMILARITY_THRESHOLD=0.3
